# Google Search Console Verification (optional)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-code

# Node Environment (automatically set by deployment platform)
NODE_ENV=production

# OpenRouter Configuration
# Get your API key from https://openrouter.ai/
OPENROUTER_API_KEY=your-openrouter-api-key

# OpenRouter Model Configuration
# Blog generation model (e.g., openai/gpt-4o-mini, anthropic/claude-3-haiku, etc.)
OPENROUTER_BLOG_MODEL=openai/gpt-4o-mini

# Fact-checking model (e.g., openai/gpt-4o-mini, anthropic/claude-3-haiku, etc.)
OPENROUTER_FACT_CHECK_MODEL=openai/gpt-4o-mini

# Cron Security
# Generate a secure random string for cron endpoint protection
CRON_SECRET=your-secret-token-for-cron-protection

# Revalidation Secret
# Generate a secure random string for revalidation endpoint protection
REVALIDATE_SECRET=your-secret-for-revalidation

# Blog Configuration
# Set to true to auto-publish blog posts that pass fact-checking
BLOG_AUTO_PUBLISH=true

# RSS Feeds (comma-separated)
# Add RSS feed URLs for accessibility articles
# Example: https://www.a11yproject.com/feed/,https://webaim.org/blog/feed/
RSS_FEEDS=https://www.a11yproject.com/feed/,https://webaim.org/blog/feed/,https://www.deque.com/blog/feed/,https://www.accessibility.com/blog/feed

# Optional: News API
# Get your API key from https://newsapi.org/
NEWS_API_KEY=optional-news-api-key

# Site URL (for revalidation)
# Set automatically by Vercel, but can be overridden
NEXT_PUBLIC_URL=https://thewcag.com

# --- Sentry error monitoring (optional) ---
# Free tier covers a solo project for years. Get DSN from https://sentry.io.
# Server + client both need a DSN. They can be the same value.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Source-map upload at build time. Only needed if you want symbolicated stack
# traces in production. SENTRY_AUTH_TOKEN must be set in CI/Vercel env.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Quiz leaderboard storage — Upstash Redis (recommended for production)
# Without these, scores are written to lib/quiz-scores/scores.json which does
# NOT persist on Vercel's read-only filesystem. Provision a free Upstash
# Redis database (https://upstash.com) and paste the REST URL + token here.
# Vercel KV provides the same envs under KV_REST_API_URL / KV_REST_API_TOKEN
# and is also auto-detected.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
